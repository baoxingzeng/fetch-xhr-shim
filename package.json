{
  "name": "fetch-xhr-shim",
  "version": "1.0.4",
  "license": "MIT",
  "author": "Xingzeng Bao",
  "homepage": "https://github.com/baoxingzeng/fetch-xhr-shim",
  "description": "A globalThis.fetch JavaScript polyfill.",
  "type": "module",
  "main": "dist/fetch-xhr-shim.cjs.js",
  "module": "dist/fetch-xhr-shim.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "polyfill.js",
    "!dist/types/**/*",
    "!dist/cjs/types/**/*",
    "!dist/esm/types/**/*"
  ],
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dev": {
      "require": "./dist/cjs/dev.js",
      "import": "./dist/esm/dev.js",
      "types": "./dist/dev.d.ts"
    },
    "./polyfill": {
      "require": "./dist/cjs/polyfill.js",
      "import": "./dist/esm/polyfill.js"
    }
  },
  "sideEffects": [
    "./dist/cjs/polyfill.js",
    "./dist/esm/polyfill.js"
  ],
  "scripts": {
    "build": "rollup --config",
    "test": "node tests/test.js",
    "test:xhr": "node tests/test-xhr.js"
  },
  "keywords": [
    "fetch",
    "polyfill"
  ],
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "formidable": "^3.5.4",
    "rollup": "^4.61.0",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "uvu": "^0.5.6",
    "xhr2": "^0.2.1"
  }
}
